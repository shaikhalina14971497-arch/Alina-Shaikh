/* CERTIFICATE GALLERY */
.gallery {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
gap: 20px;
margin-top: 20px;
}

.gallery-item {
background: white;
padding: 15px;
border-radius: 10px;
text-align: center;
box-shadow: 0 4px 10px rgba(0,0,0,0.1);
transition: transform 0.3s;
}

.gallery-item:hover {
transform: scale(1.05);
}

.gallery-item img {
width: 100%;
height: 200px;
object-fit: cover;
border-radius: 8px;
margin-bottom: 10px;
}
